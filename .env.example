# ─────────────────────────────────────────────────────────────
# myKaarma credentials  — these come from myKaarma (sent to Zach)
# ─────────────────────────────────────────────────────────────
MYKAARMA_USERNAME=
MYKAARMA_PASSWORD=
MYKAARMA_DEALER_UUID=
MYKAARMA_DEPARTMENT_UUID=

# Base URL (leave as-is unless myKaarma gives you a different sandbox host)
MYKAARMA_BASE_URL=https://api.mykaarma.com

# ─────────────────────────────────────────────────────────────
# Behaviour
# ─────────────────────────────────────────────────────────────
# How many appointment times to hand the voice agent.
# Keep it low — she has to read them out loud on a phone call.
MAX_SLOTS=3

# Fallback appointment length (minutes) when the opcode has no duration.
DEFAULT_APPOINTMENT_MINUTES=60

# Used when GHL doesn't send a dealer_key (single-store V1).
DEFAULT_DEALER_KEY=mcgrath_honda_stcharles

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
